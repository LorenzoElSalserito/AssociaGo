{
  "name": "desktop",
  "version": "1.0.0",
  "description": "An Electron application with React",
  "main": "./out/main/index.js",
  "author": "Lorenzo DM",
  "homepage": "https://github.com/lorenzodm/AssociaGo",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "node scripts/download-jre.js",
    "build:unpack": "npm run prebuild && npm run build && electron-builder --dir",
    "build:win": "npm run prebuild && npm run build && electron-builder --win",
    "build:mac": "npm run prebuild && npm run build && electron-builder --mac",
    "build:linux": "npm run prebuild && npm run build && electron-builder --linux",
    "dist": "cd .. && ./gradlew bootJar && cd desktop && npm run prebuild && electron-vite build && electron-builder",
    "dist:win": "cd .. && ./gradlew bootJar && cd desktop && npm run prebuild && electron-vite build && electron-builder --win",
    "dist:mac": "cd .. && ./gradlew bootJar && cd desktop && npm run prebuild && electron-vite build && electron-builder --mac",
    "dist:linux": "cd .. && ./gradlew bootJar && cd desktop && npm run prebuild && electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tanstack/react-table": "^8.11.8",
    "axios": "^1.6.7",
    "bootstrap": "^5.3.3",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "electron-updater": "^6.1.7",
    "i18next": "^23.8.2",
    "lucide-react": "^0.330.0",
    "react-bootstrap": "^2.10.2",
    "react-hook-form": "^7.50.1",
    "react-i18next": "^14.0.5",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.2.1",
    "yup": "^1.3.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "build": {
    "appId": "com.lorenzodm.associago",
    "productName": "AssociaGo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../build/libs",
        "to": "backend-libs",
        "filter": ["*.jar", "!*-plain.jar"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "src/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "title": "AssociaGo ${version}"
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "publisherName": "Lorenzo DM"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AssociaGo",
      "artifactName": "AssociaGo-Setup-${version}.${ext}",
      "perMachine": true,
      "allowElevation": true,
      "installerLanguages": ["en_US", "it_IT"],
      "language": 1033,
      "menuCategory": "AssociaGo",
      "uninstallDisplayName": "AssociaGo ${version}"
    },
    "linux": {
      "icon": "src/assets/icon.png",
      "category": "Office",
      "target": [
        "AppImage",
        "snap",
        "deb"
      ],
      "desktop": {
        "Icon": "/usr/share/icons/hicolor/1080x1080/apps/desktop.png"
      }
    }
  }
}
